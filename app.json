{
  "expo": {
    "name": "SignalMap",
    "slug": "signalmap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#22C55E"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SignalMap needs location to map cellular coverage in your area.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SignalMap needs background location to continuously map coverage while you move."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#22C55E"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "READ_PHONE_STATE",
        "NEARBY_WIFI_DEVICES",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "package": "com.knayx.signalmap"
    },
    "plugins": [
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "locationAlwaysAndWhenInUsePermission": "SignalMap needs background location to keep mapping coverage while the screen is off.",
          "locationAlwaysPermission": "SignalMap needs background location to keep mapping coverage while the screen is off.",
          "locationWhenInUsePermission": "SignalMap needs location to map network coverage."
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxImpl": "mapbox",
          "RNMapboxDownloadToken": "YOUR_MAPBOX_DOWNLOAD_TOKEN"
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "59859db6-0c5b-4b30-816e-12616d697a94"
      }
    },
    "owner": "knayx"
  }
}
